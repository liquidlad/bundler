{
  "name": "bundler",
  "version": "0.1.0",
  "description": "Pump.fun Bundle Bot — Auto-launch + multi-wallet bundler with tweet-triggered deployment",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "launch": "ts-node src/index.ts --mode launch",
    "monitor": "ts-node src/index.ts --mode monitor",
    "generate-wallets": "ts-node scripts/generate-wallets.ts",
    "fund-wallets": "ts-node scripts/fund-wallets.ts",
    "gather-funds": "ts-node scripts/gather-funds.ts",
    "check-balances": "ts-node scripts/check-balances.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0",
    "jito-ts": "^4.1.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "ts-node": "^10.9.0",
    "@types/node": "^22.0.0"
  }
}
